{
  "rewrites": [
    { "source": "/sv", "destination": "/index.html" },
    { "source": "/sv/", "destination": "/index.html" },
    { "source": "/en", "destination": "/index.html" },
    { "source": "/en/", "destination": "/index.html" },
    { "source": "/sv/:path+", "destination": "/:path+" },
    { "source": "/en/:path+", "destination": "/:path+" }
  ],
  "redirects": [
    { "source": "/:path*", "has": [{ "type": "host", "value": "simulate-networth.vercel.app" }], "destination": "https://cashcalcs.com/net-worth", "statusCode": 301 },
    { "source": "/", "destination": "/sv/", "statusCode": 302 }
  ]
}
